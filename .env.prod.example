# Copy this file to .env.prod on the production server and replace every
# placeholder. Never commit .env.prod.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres:replace-with-the-same-password@db:5432/postgres

SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
ACTIVATION_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15
PASSWORD_RESET_COOLDOWN_MINUTES=15
ACTIVATION_EMAIL_COOLDOWN_MINUTES=120
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

POSTMARK_KEY=replace-with-postmark-server-token
EMAIL_FROM=do-not-reply@hackthevalley.io

FRONTEND_URL=https://hackthevalley.io
BACKEND_URL=https://htb.hackthevalley.io
CORS_ORIGINS=https://hackthevalley.io,https://admin.hackthevalley.io,https://app.hackthevalley.io
ENABLE_API_DOCS=false

UPLOAD_DIR=/htb/media
MAX_FILE_SIZE_MB=5

EVENT_NAME=Hack the Valley
EVENT_START_DATE=2025-10-03T00:00:00-04:00
EVENT_END_DATE=2025-10-05T23:59:59-04:00
EVENT_LOCATION=IA building, UofT Scarborough
APPLICATION_START_DATE=2025-06-01T00:00:00-04:00
APPLICATION_END_DATE=2025-09-01T00:00:00-04:00
RSVP_DUE_DATE=September 26th 2025

APPLE_TEAM_IDENTIFIER=
APPLE_PASS_TYPE_IDENTIFIER=
APPLE_WALLET_KEY_PASSWORD=
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLASS_ID=
GOOGLE_WALLET_PASS_URL=
